@page "{assignmentId:int}"
@model LMS.Pages.Assignments.SubmissionsModel

@{
    ViewData["Title"] = "Submissions";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Submissions - @Model.Assignment?.Title</h2>
        <a class="btn btn-link" asp-page="/Assignments/Index" asp-route-courseId="@Model.Assignment?.CourseId">← Back to Assignments</a>
    </div>

    <!-- Grade Distribution Pie Chart -->
    @if (Model.GradeDistribution.GradeCategories.Any())
    {
        <div class="card mb-4">
            <div class="card-header">
                <h4>Grade Distribution</h4>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <canvas id="gradeDistributionPieChart" style="max-height: 350px; width: 100%;"></canvas>
                    </div>
                    <div class="col-md-6">
                        <div class="card bg-light">
                            <div class="card-body">
                                <h5>Class Performance Summary</h5>
                                <hr />
                                <div class="row">
                                    <div class="col-md-6">
                                        <p><strong>Total Submissions:</strong> <span class="badge bg-primary">@Model.GradeDistribution.TotalStudents</span></p>
                                        <p><strong>Graded:</strong> <span class="badge bg-success">@Model.GradeDistribution.GradedStudents</span></p>
                                        <p><strong>Ungraded:</strong> <span class="badge bg-secondary">@Model.GradeDistribution.UngradedStudents</span></p>
                                    </div>
                                    <div class="col-md-6">
                                        @if (Model.GradeDistribution.GradedStudents > 0)
                                        {
                                            <p><strong>Average Grade:</strong> <span class="badge bg-info">@Model.GradeDistribution.AverageGrade / @Model.Assignment?.Points</span></p>
                                            <p><strong>Average Percentage:</strong> <span class="badge bg-info">@Model.GradeDistribution.AveragePercentage%</span></p>
                                            <p><strong>Highest Grade:</strong> <span class="badge bg-success">@Model.GradeDistribution.HighestGrade / @Model.Assignment?.Points</span></p>
                                            <p><strong>Lowest Grade:</strong> <span class="badge bg-danger">@Model.GradeDistribution.LowestGrade / @Model.Assignment?.Points</span></p>
                                        }
                                    </div>
                                </div>
                                <hr />
                                <h6>Grade Breakdown:</h6>
                                <div class="mt-2">
                                    @foreach (var category in Model.GradeDistribution.GradeCategories)
                                    {
                                        <div class="mb-2">
                                            <div class="d-flex justify-content-between align-items-center">
                                                <span>
                                                    @if (category.Name.Contains("A"))
                                                    {
                                                        <span class="badge" style="background-color: #28a745;">●</span>
                                                    }
                                                    else if (category.Name.Contains("B"))
                                                    {
                                                        <span class="badge" style="background-color: #17a2b8;">●</span>
                                                    }
                                                    else if (category.Name.Contains("C"))
                                                    {
                                                        <span class="badge" style="background-color: #ffc107;">●</span>
                                                    }
                                                    else if (category.Name.Contains("D"))
                                                    {
                                                        <span class="badge" style="background-color: #fd7e14;">●</span>
                                                    }
                                                    else if (category.Name.Contains("F"))
                                                    {
                                                        <span class="badge" style="background-color: #dc3545;">●</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge" style="background-color: #6c757d;">●</span>
                                                    }
                                                    @category.Name
                                                </span>
                                                <span>
                                                    <strong>@category.Count</strong> students 
                                                    <span class="text-muted">(@category.Percentage.ToString("F1")%)</span>
                                                </span>
                                            </div>
                                            <div class="progress mt-1" style="height: 8px;">
                                                <div class="progress-bar" role="progressbar" 
                                                     style="width: @category.Percentage%; 
                                                            @if (category.Name.Contains("A")) { <text>background-color: #28a745;</text> }
                                                            else if (category.Name.Contains("B")) { <text>background-color: #17a2b8;</text> }
                                                            else if (category.Name.Contains("C")) { <text>background-color: #ffc107;</text> }
                                                            else if (category.Name.Contains("D")) { <text>background-color: #fd7e14;</text> }
                                                            else if (category.Name.Contains("F")) { <text>background-color: #dc3545;</text> }
                                                            else { <text>background-color: #6c757d;</text> }"
                                                     aria-valuenow="@category.Percentage" aria-valuemin="0" aria-valuemax="100">
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else if (Model.Submissions.Any())
    {
        <div class="alert alert-info mb-4">
            No graded submissions yet. Grades will appear here once you start grading.
        </div>
    }

    <!-- Submissions Table -->
    @if (!Model.Submissions.Any())
    {
        <div class="alert alert-info">
            No submissions yet.
        </div>
    }
    else
    {
        <div class="card">
            <div class="card-header">
                <h4>Student Submissions</h4>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>Student Name</th>
                                <th>Submitted</th>
                                <th>Status</th>
                                <th>Grade</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Submissions)
                            {
                                <tr>
                                    <td>@item.FirstName @item.LastName</td>
                                    <td>@item.SubmittedAt.ToString("MMM d, yyyy h:mm tt")</td>
                                    <td>
                                        @if (item.Status == "Graded")
                                        {
                                            <span class="badge bg-success">Graded</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark">Submitted</span>
                                        }
                                    </td>
                                    <td>
                                        @if (item.Grade > 0)
                                        {
                                            <strong>@item.Grade</strong> <span class="text-muted">/ @Model.Assignment?.Points</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Not graded</span>
                                        }
                                    </td>
                                    <td>
                                        @if (item.Status == "Graded")
                                        {
                                            <a class="btn btn-sm btn-outline-secondary"
                                               asp-page="/Assignments/GradeSubmissions"
                                               asp-route-submissionId="@item.SubmissionId">
                                                Edit Grade
                                            </a>
                                        }
                                        else
                                        {
                                            <a class="btn btn-sm btn-outline-primary"
                                               asp-page="/Assignments/GradeSubmissions"
                                               asp-route-submissionId="@item.SubmissionId">
                                                Grade
                                            </a>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            @if (Model.GradeDistribution.GradeCategories.Any())
            {
                <text>
                var ctx = document.getElementById('gradeDistributionPieChart').getContext('2d');
                var gradeCategories = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.GradeDistribution.GradeCategories));
                
                var labels = gradeCategories.map(c => `${c.Name} (${c.Count} students)`);
                var counts = gradeCategories.map(c => c.Count);
                
                // Color scheme for different grade categories
                var colors = gradeCategories.map(c => {
                    if (c.Name.includes("A")) return 'rgba(40, 167, 69, 0.8)';
                    if (c.Name.includes("B")) return 'rgba(23, 162, 184, 0.8)';
                    if (c.Name.includes("C")) return 'rgba(255, 193, 7, 0.8)';
                    if (c.Name.includes("D")) return 'rgba(253, 126, 20, 0.8)';
                    if (c.Name.includes("F")) return 'rgba(220, 53, 69, 0.8)';
                    return 'rgba(108, 117, 125, 0.8)'; // Gray for Not Graded
                });
                
                var borderColors = colors.map(c => c.replace('0.8', '1'));
                
                new Chart(ctx, {
                    type: 'pie',
                    data: {
                        labels: labels,
                        datasets: [{
                            data: counts,
                            backgroundColor: colors,
                            borderColor: borderColors,
                            borderWidth: 2
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: true,
                        plugins: {
                            legend: {
                                position: 'bottom',
                                labels: {
                                    font: {
                                        size: 12
                                    },
                                    padding: 10
                                }
                            },
                            tooltip: {
                                callbacks: {
                                    label: function(context) {
                                        var label = context.label || '';
                                        var value = context.raw;
                                        var total = @Model.GradeDistribution.TotalStudents;
                                        var percentage = ((value / total) * 100).toFixed(1);
                                        return `${label}: ${value} student${value !== 1 ? 's' : ''} (${percentage}%)`;
                                    }
                                }
                            }
                        },
                        title: {
                            display: true,
                            text: 'Assignment Grade Distribution',
                            font: {
                                size: 16,
                                weight: 'bold'
                            },
                            padding: {
                                bottom: 20
                            }
                        }
                    }
                });
                </text>
            }
        });
    </script>
}