@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using System.Text.Json
@using LMS.Data
@using LMS.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject ApplicationDbContext DbContext

@{
    var notificationJson = "[]";
    var hasMoreThanFive = false;
    var signedInUser = SignInManager.IsSignedIn(User) ? await UserManager.GetUserAsync(User) : null;

    if (signedInUser != null && User.HasClaim("UserType", "Student"))
    {
        var baseQuery = DbContext.Notifications
            .Where(n => n.UserId == signedInUser.Id && !n.NotificationDeleted)
            .OrderByDescending(n => n.CreatedAt);

        hasMoreThanFive = await baseQuery.CountAsync() > 5;

        var notifications = await baseQuery
            .Take(5)
            .Select(n => new
            {
                id = n.NotificationId,
                message = n.Message,
                type = n.NotificationType,
                createdAt = n.CreatedAt
            })
            .ToListAsync();

        notificationJson = JsonSerializer.Serialize(notifications);
    }
}

<head>
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="lib/bootstrap/dist/js/bootstrap.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <style>
        #notificationIcon {
            font-size: 30px;
            color: #333333;
        }

        #notificationBtn {
            background: transparent;
            border: none;
            padding: 0;
        }

        .popover {
            max-width: 320px;
            font-size: 16px;
            color: #333333;
        }

        .popover-header {
            font-weight: bold;
            font-size: 18px;
            color: #000000;
        }

        .popover-body {
            font-size: 16px;
            color: #333333;
        }

        .notification-row {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 10px;
            margin-bottom: 10px;
        }

        .notification-message {
            flex: 1;
            word-break: break-word;
        }

        .delete-notification {
            cursor: pointer;
            color: red;
        }

        .notification-footer {
            margin-top: 8px;
            font-size: 14px;
            color: gray;
        }
    </style>

    <script>
        $(document).ready(function () {
            var notificationShown = false;
            var notifications = @Html.Raw(notificationJson);
            var hasMoreThanFive = @Html.Raw(hasMoreThanFive.ToString().ToLower());

            function buildNotificationHtml() {
                if (!notifications || notifications.length === 0) {
                    return '<span style="color:gray;">No notifications</span>';
                }

                var html = notifications.map(function (n, index) {
                    return `
                        <div class="notification-row" data-index="${index}">
                            <span class="notification-message">${n.message ?? ''}</span>
                            <i class="fa-solid fa-xmark delete-notification" data-index="${index}"></i>
                        </div>
                    `;
                }).join('');

                if (hasMoreThanFive) {
                    html += `<div class="notification-footer">Showing 5 most recent notifications</div>`;
                }

                return html;
            }

            $('#notificationBtn').click(function () {
                if (!notificationShown) {
                    $(this).popover({
                        html: true,
                        trigger: 'manual',
                        placement: 'bottom',
                        title: 'Notifications',
                        content: buildNotificationHtml()
                    }).popover('show');

                    $('#notificationIcon').removeClass('fa-bell').addClass('fa-xmark');
                    notificationShown = true;
                } else {
                    $('#notificationBtn').popover('hide');
                    $('#notificationIcon').removeClass('fa-xmark').addClass('fa-bell');
                    notificationShown = false;
                }
            });

            $(document).on('click', '.delete-notification', function (e) {
                e.stopPropagation();

                var index = parseInt($(this).attr('data-index'));
                if (!isNaN(index)) {
                    notifications.splice(index, 1);

                    $('#notificationBtn').popover('dispose');
                    $('#notificationBtn').popover({
                        html: true,
                        trigger: 'manual',
                        placement: 'bottom',
                        title: 'Notifications',
                        content: buildNotificationHtml()
                    }).popover('show');
                }
            });

            $(document).click(function (e) {
                var target = $(e.target);
                if (!target.closest('#notificationBtn').length &&
                    !target.closest('.popover').length &&
                    notificationShown) {
                    $('#notificationBtn').popover('hide');
                    $('#notificationIcon').removeClass('fa-xmark').addClass('fa-bell');
                    notificationShown = false;
                }
            });
        });
    </script>
</head>

<ul class="navbar-nav">
    @if (SignInManager.IsSignedIn(User))
    {
        <li class="nav-item">
            <a class="nav-link text-dark" asp-page="/Profile/Index">Profile</a>
        </li>

        <li class="nav-item">
            <a class="nav-link text-dark" asp-page="/Calendar/Index">Calendar</a>
        </li>

        @if (User.HasClaim("UserType", "Student"))
        {
            <li class="nav-item">
                <a class="nav-link text-dark" asp-page="/StudentAccount/Index">Account</a>
            </li>

            <li class="nav-item">
                <a class="nav-link text-dark" asp-page="/Registrations/Create">Registration</a>
            </li>
        }
        else
        {
            <li class="nav-item">
                <a class="nav-link text-dark" href="/Courses" title="Courses">Courses</a>
            </li>
        }

        <li class="nav-item">
            <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/Index", new { area = "" })">
                <button type="submit" class="nav-link text-dark">Logout</button>
            </form>
        </li>

        @if (User.HasClaim("UserType", "Student"))
        {
            <li class="nav-item">
                <button id="notificationBtn" type="button" class="btn">
                    <i id="notificationIcon" class="fa-solid fa-bell"></i>
                </button>
            </li>
        }
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Register">Sign Up</a>
        </li>
        <li class="nav-item">
            <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Login">Login</a>
        </li>
    }
</ul>